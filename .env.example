# ─── Kakao Map (필수) ───
NEXT_PUBLIC_KAKAO_MAP_KEY=YOUR_KAKAO_JS_KEY

# ─── Firebase Web SDK (필수, apiKey 노출 정상) ───
# 콘솔: https://console.firebase.google.com/project/onek1000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=onek1000.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=onek1000
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=onek1000.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── 데이터 소스 ───
# true: mock 데이터 (개발)
# false: 실 Opinet API + Supabase
NEXT_PUBLIC_USE_MOCK=true
OPINET_API_KEY=

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Upstash Redis (선택) ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── NextAuth ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── KG이니시스 결제 ───
# 미설정 시 공식 공개 테스트 상점값으로 동작(MID: INIpayTest). 실연동 시 발급값으로 교체.
#   INICIS_MID        가맹점 MID (예: INIpayTest). 클라이언트 결제창엔 이 mid만 노출됨
#   INICIS_SIGN_KEY   표준결제창 서명용 signKey (서버 전용, 노출 금지)
#   INICIS_API_KEY    빌링 결제승인(INIAPI) Key (서버 전용, 노출 금지)
#   INICIS_CLIENT_IP  빌링 REST API 호출 시 보낼 가맹점 서버 고정 IP(이니시스 화이트리스트 등록 필요)
INICIS_MID=
INICIS_SIGN_KEY=
INICIS_API_KEY=
INICIS_CLIENT_IP=

# ─── Google AdSense (선택) ───
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_BANNER_SLOT=

# ─── Web Push (베타) ───
# 한 번만 발급: npm run vapid:gen
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@onek1000.kr

# ─── Cron 보호 ───
CRON_SECRET=change-me
