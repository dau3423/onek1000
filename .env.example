# ─── Kakao Map (필수) ───
NEXT_PUBLIC_KAKAO_MAP_KEY=YOUR_KAKAO_JS_KEY

# ─── Firebase Web SDK (필수, apiKey 노출 정상) ───
# 콘솔: https://console.firebase.google.com/project/onek1000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=onek1000.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=onek1000
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=onek1000.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── 초기 베타 전면무료 (단일 플래그) ───
# true: 프리미엄 기능을 로그인 사용자 전원에게 무료 개방 + 유료/결제 유도 노출 보류.
#       (광고 OFF·즐겨찾기 동기화·가격 변동 푸시·헤더 배지 등 isPremium 분기가 한꺼번에 열림.
#        마이페이지 /pricing CTA·헤더 프리미엄 배지·가입화면 결제약관 강조는 숨김.)
# false 또는 미설정: 기존(유료) 동작으로 완전 원복. 베타 종료 시 이 줄만 false로.
# 주의: 결제/구독/PortOne 인프라 코드는 이 플래그와 무관하게 그대로 유지된다(노출/판정만 우회).
NEXT_PUBLIC_BETA_FREE=true

# ─── 데이터 소스 ───
# true: mock 데이터 (개발)
# false: 실 Opinet API + Supabase
NEXT_PUBLIC_USE_MOCK=true
OPINET_API_KEY=
# 전기차 충전소 정보(공공데이터포털 data.go.kr EvCharger). 서버 전용(NEXT_PUBLIC_ 금지).
# 1일 1회 sync(/api/internal/sync-ev)에서만 호출. 미설정이면 EV 레이어는 mock으로 폴백.
EV_CHARGER_API_KEY=
# ─── 시장 데이터(주유 타이밍 예측 선행지표) ───
# /api/internal/sync-market 가 1일 1회 적재(국제유가/MOPS/USD-KRW/국내 전국평균 소매가).
# 별도 API 키 불필요(Opinet 웹 CSV 세션 + Yahoo 공개 JSON). CRON_SECRET + Supabase 로만 동작.
# 최초 백필: POST /api/internal/sync-market?from=YYYYMMDD (Authorization: Bearer ${CRON_SECRET})

# ─── Supabase (NEXT_PUBLIC_USE_MOCK=false일 때 필수) ───
# 모든 DB 접근은 API Routes(서버)에서 service_role 키로만 수행한다.
NEXT_PUBLIC_SUPABASE_URL=
# 현재 코드 미사용(클라이언트 직접 접근 안 함). 향후 대비 + 표준 키라 자리만 유지.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — 절대 NEXT_PUBLIC_ 금지
SUPABASE_SERVICE_ROLE_KEY=

# ─── Upstash Redis (선택) ───
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── NextAuth ───
NEXTAUTH_URL=http://localhost:3000
# NextAuth가 내부적으로 자동 참조(코드 직접 호출 없음). 운영 배포 시 필수.
#   생성: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 관리자 결제 알림 (선택, 서버 전용 — 절대 NEXT_PUBLIC_ 금지) ───
# 결제 발생 시 관리자(앱 소유자) 본인 카카오톡 "나에게 보내기"로 무료 알림.
# 관리자 본인이 talk_message 동의로 발급한 refresh_token 을 넣는다(KAKAO_CLIENT_ID/SECRET 재사용).
# 미설정 시 알림 기능은 조용히 비활성(결제 흐름엔 영향 없음). 발급 가이드는 카카오 OAuth 문서 참고.
ADMIN_KAKAO_REFRESH_TOKEN=

# ─── 심사용 로그인 (선택, 서버 전용 — 절대 NEXT_PUBLIC_ 금지) ───
# 결제 심사팀이 구글 2FA로 로그인 못 할 때 쓰는 임시 단일 계정.
# 두 값이 모두 설정된 경우에만 ID/비밀번호 로그인 폼이 노출/활성된다.
# 미설정 시 provider 자체가 없어 일반 사용자에게 노출되지 않는다.
# 심사 종료 후 두 값을 제거하면 즉시 비활성. 비밀번호는 강한 임의 문자열 사용 권장.
REVIEWER_EMAIL=
REVIEWER_PASSWORD=

# ─── 포트원(PortOne) v2 결제 ───
# 결제는 포트원 v2(이니시스 단건/정기 + 카카오페이 단건/정기)로 한다.
#
# [공개값] storeId/channelKey 는 클라이언트 노출 정상. 미설정 시 코드 폴백 상수 사용.
#   NEXT_PUBLIC_PORTONE_STORE_ID                   상점 ID
#   NEXT_PUBLIC_PORTONE_CHANNEL_INICIS_ONETIME     이니시스 단건 채널키
#   NEXT_PUBLIC_PORTONE_CHANNEL_INICIS_RECURRING   이니시스 정기 채널키
#   NEXT_PUBLIC_PORTONE_CHANNEL_KAKAOPAY_ONETIME   카카오페이 단건 채널키
#   NEXT_PUBLIC_PORTONE_CHANNEL_KAKAOPAY_RECURRING 카카오페이 정기 채널키
NEXT_PUBLIC_PORTONE_STORE_ID=
NEXT_PUBLIC_PORTONE_CHANNEL_INICIS_ONETIME=
NEXT_PUBLIC_PORTONE_CHANNEL_INICIS_RECURRING=
NEXT_PUBLIC_PORTONE_CHANNEL_KAKAOPAY_ONETIME=
NEXT_PUBLIC_PORTONE_CHANNEL_KAKAOPAY_RECURRING=
#
# [서버 전용] 절대 NEXT_PUBLIC_ 금지.
#   PORTONE_API_SECRET     V2 REST API Secret. 미설정 시 결제 진입 차단(subscribe 503, Mock 회귀 없음)
#   PORTONE_WEBHOOK_SECRET 웹훅 서명검증 시크릿(whsec_...). 미설정 시 서명검증 스킵 + GET 재검증만 수행
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=

# ─── Google AdSense (선택) ───
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_BANNER_SLOT=

# ─── Web Push (베타) ───
# 한 번만 발급: npm run vapid:gen
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@onek1000.kr

# ─── Cron 보호 ───
CRON_SECRET=change-me
